{
  "tables": [
    { "name": "customers", "description": "Primary customer master with soft-merge fields", "keys": ["_id", "displayName", "mobileNumber", "emailId", "active", "isMerged", "mergedInto"] },
    { "name": "customer_addresses", "description": "Normalized billing/shipping addresses per customer", "keys": ["_id", "customerId", "type", "address", "state", "pincode", "active"] },
    { "name": "customer_contacts", "description": "Primary and alternate customer contacts", "keys": ["_id", "customerId", "type", "value", "isPrimary", "active"] },
    { "name": "customer_import_batches", "description": "Import wizard batch metadata", "keys": ["_id", "fileName", "status", "headers", "mapping", "stats", "createdAt"] },
    { "name": "customer_import_rows", "description": "Normalized import rows with row-level action and final result", "keys": ["_id", "batchId", "rowNumber", "status", "confidence", "selectedAction", "finalResult"] },
    { "name": "customer_duplicate_matches", "description": "Stored duplicate candidates for imported rows", "keys": ["_id", "batchId", "importRowId", "existingCustomerId", "confidence", "reason"] },
    { "name": "customer_merge_history", "description": "Merge history log with source/target snapshots", "keys": ["_id", "sourceCustomerId", "targetCustomerId", "reason", "actor", "createdAt"] },
    { "name": "customer_dedup_audit", "description": "Audit log for dedupe/import/merge actions", "keys": ["_id", "action", "actor", "payload", "createdAt"] }
  ]
}
