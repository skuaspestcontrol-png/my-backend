# Server
PORT=5000
SERVER_ORIGIN=https://crm.skuaspestcontrol.com
CORS_ALLOWED_ORIGINS=https://crm.skuaspestcontrol.com

# SMTP fallback (optional if configured via Settings UI)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# WhatsApp Cloud API fallback (optional if configured via Settings UI)
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Google Maps Geocoding API (used by Lead -> Search Address)
GOOGLE_MAPS_API_KEY=

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=skuas_crm
